# ═══════════════════════════════════════════════════════════
# OmicsLab — Environment Variables
# Copy this file to .env.local for local dev (never commit .env.local)
# Add these as Environment Variables in Vercel dashboard
# ═══════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────
# Get from: supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Clerk ─────────────────────────────────────────────────
# Get from: dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_your_key_here
CLERK_SECRET_KEY=sk_live_your_key_here

# ── Stripe ────────────────────────────────────────────────
# NOT currently used by the pricing page (js/pricing.js only calls
# /api/create-paystack-checkout) — api/create-checkout.js and
# api/stripe-webhook.js are unused unless something re-enables them.
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create in Stripe dashboard → Products)
STRIPE_PRICE_CAMPUS=price_campus_monthly_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly_id

# ── Paystack ──────────────────────────────────────────────
# This IS the active checkout path (js/pricing.js → api/create-paystack-checkout.js).
# Get PAYSTACK_SECRET_KEY from: dashboard.paystack.com → Settings → API Keys & Webhooks
# (the same secret key is also used to verify webhook signatures — no separate
# webhook secret exists for Paystack, unlike Stripe)
PAYSTACK_SECRET_KEY=sk_live_your_key_here

# Plan codes (create each as a Plan in dashboard.paystack.com → Products → Plans —
# amount must match js/pricing.js's IND_TIERS priceM/priceY/studentM/studentY,
# currency ZAR): six plans total — Scholar and Practitioner, each monthly/annual,
# plus a discounted student rate for Scholar only (Practitioner has no student rate).
PAYSTACK_PLAN_SCHOLAR_MONTHLY=PLN_your_plan_code_here
PAYSTACK_PLAN_SCHOLAR_MONTHLY_STUDENT=PLN_your_plan_code_here
PAYSTACK_PLAN_SCHOLAR_ANNUAL=PLN_your_plan_code_here
PAYSTACK_PLAN_SCHOLAR_ANNUAL_STUDENT=PLN_your_plan_code_here
PAYSTACK_PLAN_PRACTITIONER_MONTHLY=PLN_your_plan_code_here
PAYSTACK_PLAN_PRACTITIONER_ANNUAL=PLN_your_plan_code_here

# Also set the webhook URL in dashboard.paystack.com → Settings → API Keys & Webhooks:
#   https://omicsdatalab.tech/api/paystack-webhook

# ── Resend ────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@omicsdatalab.tech

# ── Sentry ────────────────────────────────────────────────
# Get from: sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ── PostHog ───────────────────────────────────────────────
# Get from: app.posthog.com → Project Settings
POSTHOG_KEY=phc_your_key_here
POSTHOG_HOST=https://app.posthog.com

# ── Upstash (Redis) ───────────────────────────────────────
# Get from: console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Pinecone ──────────────────────────────────────────────
# Get from: app.pinecone.io → API Keys
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX=omicslab-knowledge
PINECONE_HOST=https://omicslab-knowledge-xxx.svc.pinecone.io

# ── Anthropic (Claude — for AI features) ─────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://omicsdatalab.tech
